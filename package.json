{
  "name": "archivistpro",
  "private": true,
  "license": "MIT",
  "version": "2.4.5",
  "type": "module",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');const path=require('path');fs.mkdirSync('public',{recursive:true});fs.copyFileSync('node_modules/sql.js/dist/sql-wasm.wasm','public/sql-wasm.wasm');fs.mkdirSync('public/ort',{recursive:true});for(const f of fs.readdirSync('node_modules/@xenova/transformers/dist').filter(n=>n.startsWith('ort-wasm')&&n.endsWith('.wasm'))){fs.copyFileSync(path.join('node_modules/@xenova/transformers/dist',f),path.join('public/ort',f));}\"",
    "dev": "vite",
    "dev:admin": "vite --mode admin",
    "dev:viewer": "vite --mode viewer",
    "build": "npm run models:check && tsc -b && vite build",
    "build:admin": "npm run models:check && tsc -b && vite build --mode admin",
    "build:viewer": "npm run models:check && tsc -b && vite build --mode viewer",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "tauri": "tauri",
    "models:download": "node scripts/download-models.cjs",
    "models:check": "node -e \"const fs=require('fs');const m=['public/models/Xenova/paraphrase-multilingual-MiniLM-L12-v2/onnx/model_quantized.onnx','public/models/Xenova/clip-vit-base-patch32/onnx/vision_model_quantized.onnx'];const missing=m.filter(p=>!fs.existsSync(p));if(missing.length){console.log('Model dosyalari eksik ('+missing.length+'), indiriliyor...');require('child_process').execSync('node scripts/download-models.cjs',{stdio:'inherit'});}else{console.log('Modeller hazir (MiniLM + CLIP).');}\"",
    "predev": "npm run models:check",
    "offline:prepare": "powershell -ExecutionPolicy Bypass -File scripts/prepare-offline-assets.ps1",
    "offline:build": "powershell -ExecutionPolicy Bypass -File scripts/build-offline-msi.ps1",
    "offline:build:msi": "powershell -ExecutionPolicy Bypass -File scripts/build-offline-msi.ps1 -MsiOnly",
    "offline:build:nsis": "powershell -ExecutionPolicy Bypass -File scripts/build-offline-msi.ps1 -NsisOnly"
  },
  "dependencies": {
    "@fontsource-variable/sora": "^5.2.8",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-http": "^2.5.8",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@xenova/transformers": "^2.17.2",
    "dompurify": "^3.3.3",
    "i18next": "^26.0.3",
    "lucide-react": "^0.577.0",
    "p-limit": "^7.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.13.1",
    "react-virtuoso": "^4.18.4",
    "recharts": "^3.8.1",
    "sql.js": "^1.14.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
