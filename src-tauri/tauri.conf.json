{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ArchivistPro",
  "version": "2.4.5",
  "identifier": "com.archivistpro.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Archivist Pro",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; connect-src 'self' blob: ipc: http://ipc.localhost http://localhost:11434 http://127.0.0.1:11434 http://localhost:9471 http://127.0.0.1:9471; font-src 'self' data:; worker-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/com.archivistpro.desktop/**", "$RESOURCE/**", "**"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": "^https?://|^mailto:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installMode": "both"
      }
    },
    "resources": [
      "resources/*"
    ]
  }
}